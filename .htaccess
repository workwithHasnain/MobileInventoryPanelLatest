# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    # RewriteBase is removed so that Apache handles subdirectories dynamically
    
    # Don't rewrite if it's a real file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Route AJAX and other handlers to handlers/ directory
    RewriteRule ^api_get_devices\.php$ handlers/api_get_devices.php [L,QSA]
    RewriteRule ^api_get_posts\.php$ handlers/api_get_posts.php [L,QSA]
    RewriteRule ^api_get_rumored_devices\.php$ handlers/api_get_rumored_devices.php [L,QSA]
    RewriteRule ^api_get_brand_devices\.php$ handlers/api_get_brand_devices.php [L,QSA]
    RewriteRule ^handle_newsletter\.php$ handlers/handle_newsletter.php [L,QSA]
    RewriteRule ^notification_handler\.php$ handlers/notification_handler.php [L,QSA]
    RewriteRule ^load_posts\.php$ handlers/load_posts.php [L,QSA]
    RewriteRule ^ajax_comment_handler\.php$ handlers/ajax_comment_handler.php [L,QSA]
    RewriteRule ^handle_contact\.php$ handlers/handle_contact.php [L,QSA]
    RewriteRule ^manifest\.json$ handlers/manifest.json [L,QSA]
    RewriteRule ^captcha\.php$ handlers/captcha.php [L,QSA]
    RewriteRule ^search\.php$ handlers/search.php [L,QSA]
    
    # Redirect to https://www (only on production, not localhost)
    RewriteCond %{HTTP_HOST} ^devicesarena\.com$ [NC]
    RewriteRule ^(.*)$ https://www.devicesarena.com/$1 [R=301,L]
    
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
    RewriteCond %{HTTP_HOST} ^(?!www\.).*$ [NC]
    RewriteCond %{HTTPS} !=on
    RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [R=301,L]

    # Route for brands.php: /brands
    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^brands\.php/?$ brands [R=301,L]
    RewriteRule ^brands/?$ brands.php [L,QSA]

    # Route for /brand (no slug) -> redirect to /brands
    RewriteRule ^brand/?$ brands.php [L,QSA]

    # Route for brand.php: /brand/slug (brand detail page with devices)
    RewriteRule ^brand/([a-zA-Z0-9\-]+)/?$ brand.php?slug=$1 [L,QSA]

    # Route for compare.php: /compare
    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^compare\.php/?$ compare [R=301,L]
    RewriteRule ^compare/?$ compare.php [L,QSA]

    # Route for compare.php: compare/slug1-vs-slug2-vs-slug3
    RewriteRule ^compare/(.+)/?$ compare.php?slugs=$1 [L,QSA]

    # Route for device images: /device/slug/images
    RewriteRule ^device/([a-z0-9\-]+)/images/?$ device-images.php?slug=$1 [L,QSA]

    # Route for device.php: /device/slug
    RewriteRule ^device/([a-z0-9\-]+)/?$ device.php?slug=$1 [L,QSA]

    # Route for post.php: /post/slug
    RewriteRule ^post/([a-z0-9\-]+)/?$ post.php?slug=$1 [L,QSA]

    # Route for featured.php: /featured
    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^featured\.php/?$ featured [R=301,L]
    RewriteRule ^featured/?$ featured.php [L,QSA]

    # Route for reviews.php: /reviews
    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^reviews\.php/?$ reviews [R=301,L]
    RewriteRule ^reviews/?$ reviews.php [L,QSA]

    # Route for news.php: /news
    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^news\.php/?$ news [R=301,L]
    RewriteRule ^news/?$ news.php [L,QSA]

    # Route for rumored.php: /rumored
    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^rumored\.php/?$ rumored [R=301,L]
    RewriteRule ^rumored/?$ rumored.php [L,QSA]

    # Route for phonefinder.php: /phonefinder
    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^phonefinder\.php/?$ phonefinder [R=301,L]
    RewriteRule ^phonefinder/?$ phonefinder.php [L,QSA]

    # Route for about-us.php: /about-us
    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^about-us\.php/?$ about-us [R=301,L]
    RewriteRule ^about-us/?$ about-us.php [L,QSA]

    # Route for contact-us.php: /contact-us
    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^contact-us\.php/?$ contact-us [R=301,L]
    RewriteRule ^contact-us/?$ contact-us.php [L,QSA]

    # Route for advertise-with-us.php: /advertise-with-us
    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^advertise-with-us\.php/?$ advertise-with-us [R=301,L]
    RewriteRule ^advertise-with-us/?$ advertise-with-us.php [L,QSA]

    # Route for privacy-policy.php: /privacy-policy
    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^privacy-policy\.php/?$ privacy-policy [R=301,L]
    RewriteRule ^privacy-policy/?$ privacy-policy.php [L,QSA]

    # Redirect /home to current directory root
    RewriteRule ^home/?$ ./ [R=301,L]

    # Redirect /index.php to current directory root
    RewriteRule ^index\.php/?$ ./ [R=301,L]


    # Routes for new pages

    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^terms-of-use\.php/?$ terms-of-use [R=301,L]
    RewriteRule ^terms-of-use/?$ terms-of-use.php [L,QSA]

    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^web-notifications\.php/?$ web-notifications [R=301,L]
    RewriteRule ^web-notifications/?$ web-notifications.php [L,QSA]

    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^cookies\.php/?$ cookies [R=301,L]
    RewriteRule ^cookies/?$ cookies.php [L,QSA]

    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^reprint-and-publishing\.php/?$ reprint-and-publishing [R=301,L]
    RewriteRule ^reprint-and-publishing/?$ reprint-and-publishing.php [L,QSA]

    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^database-licensing\.php/?$ database-licensing [R=301,L]
    RewriteRule ^database-licensing/?$ database-licensing.php [L,QSA]

    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^ethics-statement\.php/?$ ethics-statement [R=301,L]
    RewriteRule ^ethics-statement/?$ ethics-statement.php [L,QSA]

    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^how-we-rate\.php/?$ how-we-rate [R=301,L]
    RewriteRule ^how-we-rate/?$ how-we-rate.php [L,QSA]

    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^ai-at-devicesarena\.php/?$ ai-at-devicesarena [R=301,L]
    RewriteRule ^ai-at-devicesarena/?$ ai-at-devicesarena.php [L,QSA]

    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^team\.php/?$ team [R=301,L]
    RewriteRule ^team/?$ team.php [L,QSA]

    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^careers\.php/?$ careers [R=301,L]
    RewriteRule ^careers/?$ careers.php [L,QSA]

    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^news-archive\.php/?$ news-archive [R=301,L]
    RewriteRule ^news-archive/?$ news-archive.php [L,QSA]

    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^reviews-archive\.php/?$ reviews-archive [R=301,L]
    RewriteRule ^reviews-archive/?$ reviews-archive.php [L,QSA]

    RewriteCond %{THE_REQUEST} \.php [NC]
    RewriteRule ^sitemap\.php/?$ sitemap [R=301,L]
    RewriteRule ^sitemap/?$ sitemap.php [L,QSA]

</IfModule>
